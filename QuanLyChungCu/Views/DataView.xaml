<UserControl x:Class="QuanLyChungCu.Views.DataView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:QuanLyChungCu.Views"
             xmlns:automation="clr-namespace:System.Windows.Automation;assembly=PresentationCore"
             xmlns:Icon="http://metro.mahapps.com/winfx/xaml/iconpacks"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="39*"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>



        <!--Couter Title-->
        <TextBlock  Text="Danh Sách Các Hộ Gia Đình" Grid.Row="1" FontSize="18" FontWeight="SemiBold"
            Foreground="#121518" HorizontalAlignment="Left"
            VerticalAlignment="Center" Margin="10 0 0 0"/>

        <!--Search-->
        <StackPanel Orientation="Horizontal" Grid.Row="2" Margin="0 0 0 0" HorizontalAlignment="Left">
            <ComboBox x:Name="cmbSearchColumn"
                      automation:AutomationProperties.AutomationId="Owner.SearchColumn"
                      Style="{StaticResource CustomComboBoxStyle}"
                      ItemContainerStyle="{StaticResource ComboBoxItemStyle}"
                      Width="150" 
                      Height="30"
                      FontSize="14"
                      Margin="0,0,10,0">
                <ComboBoxItem Content="Tên" Tag="Name" IsSelected="True" />
                <ComboBoxItem Content="Số điện thoại" Tag="Phone"/>
                <ComboBoxItem Content="Số phòng" Tag="RoomNumber"/>
                <ComboBoxItem Content="Quê quán" Tag="QueQuan"/>
                <ComboBoxItem Content="Ngày sinh" Tag="BirthDate"/>
            </ComboBox>

            <Border Width="200" CornerRadius="20" Background="#ffffff" Height="30">
                <StackPanel Orientation="Horizontal">
                    <TextBox    x:Name="txtSearch" Background="Transparent"
                                automation:AutomationProperties.AutomationId="Owner.SearchInput"
                                Width="160" BorderBrush="Transparent"
                                Height="30"
                                FontSize="15" 
                                Margin="10,0,0,0"
                                VerticalContentAlignment="Center"
                                Text="Nhập từ khóa..."         
                                Foreground="Gray"
                                GotFocus="txtSearch_GotFocus" 
                                LostFocus="txtSearch_LostFocus" HorizontalAlignment="Left"/>
                        <Icon:PackIconMaterial Kind="Magnify" Width="15" Height="15" 
                                VerticalAlignment="Center" 
                                Margin="0 0 0 0" Foreground="#b0b9c6"
                                HorizontalAlignment="Right"/>
                </StackPanel>
            </Border>

            <Border Width="100" 
                    Height="30" CornerRadius="10"
                    Background="#ffffff" 
                    Margin="10 0 0 0">

                <Button x:Name="btnSearch" Style="{StaticResource searchButton}" 
                        automation:AutomationProperties.AutomationId="Owner.SearchButton"
                        Content="Tìm Kiếm"
                        Width="100" Height="30"
                        Click="btnSearch_Click"
                        IsDefault="True"/>
            </Border>
            <Rectangle Width="1" Fill="#dee4ec" Margin="10 7"/>
            <Border Width="100" 
                    Height="30" CornerRadius="10"                           
                    Background="#ffffff">
                <Button x:Name="btnClearSearch" 
                        automation:AutomationProperties.AutomationId="Owner.ClearSearch"
                        Style="{StaticResource searchButton}"                              
                        Content="Xóa Lọc" 
                        Width="100" Height="30" 
                        Click="btnClearSearch_Click"/>
            </Border>
        </StackPanel>


        <!--Add Button-->
        <Button x:Name="addbutton" Style="{StaticResource addButton}" 
        automation:AutomationProperties.AutomationId="Owner.AddButton"
        Margin="0 0 0 0" Click="btnAddOwner_Click"
        Grid.Row="2">
            <Button.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#36D1DC" Offset="0.0"/>
                    <GradientStop Color="#5B86E5" Offset="1.0"/>
                </LinearGradientBrush>
            </Button.Background>
            <StackPanel Orientation="Horizontal">
                <Icon:PackIconMaterial Kind="Plus" VerticalAlignment="Center"
                                    Width="11" Height="11" Margin="0 0 8 0"/>
                <TextBlock Text="Thêm chủ hộ" Foreground="#daf4ff"/>
            </StackPanel>
        </Button>


        <DataGrid   Style="{DynamicResource DataGridStyle1}" CellStyle="{DynamicResource DataGridCellStyle1}" 
                    ColumnHeaderStyle="{DynamicResource DataGridColumnHeaderStyle1}"
                    RowStyle="{DynamicResource DataGridRowStyle1}" 
                    x:Name="MemberDataGrid"
                    automation:AutomationProperties.AutomationId="Owner.Grid"
                    Grid.Row="3">
            <DataGrid.Columns>
                <DataGridTextColumn Header="STT" IsReadOnly="True" CanUserReorder="False" Binding="{Binding STT}"
                        Width="auto"/>
                <DataGridTemplateColumn Header="Tên chủ hộ" IsReadOnly="True" Width="165">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Quê Quán" IsReadOnly="True" Width="145" Binding="{Binding QueQuan}"/>
                <DataGridTextColumn Header="SĐT" IsReadOnly="True" Width="110" Binding="{Binding Phone}"/>
                <DataGridTextColumn Header="Số Người" IsReadOnly="True" Width="*" Binding="{Binding TotalPeople}"/>
                <DataGridTextColumn Header="Số Phòng" IsReadOnly="True" Width="*" Binding="{Binding RoomNumber}"/>
                <DataGridTemplateColumn Header="Chức năng" IsReadOnly="True" Width="auto">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button Style="{StaticResource grideditButton}" Click="EditOwner_Click" 
                                    automation:AutomationProperties.AutomationId="Owner.EditButton"
                                    automation:AutomationProperties.Name="Owner.Edit"
                                    Tag="{Binding}">
                                    <Icon:PackIconMaterial Kind="PencilOutline" Style="{StaticResource GridButtunIcon}"/>
                                </Button>
                                <Button Style="{StaticResource gridRemoveButton}" Margin="5 0 0 0" Click="DeleteOwner_Click" 
                                    automation:AutomationProperties.AutomationId="Owner.DeleteButton"
                                    automation:AutomationProperties.Name="Owner.Delete"
                                    Tag="{Binding}">
                                    <Icon:PackIconMaterial Kind="DeleteOutline" Style="{StaticResource GridButtunIcon}"/>
                                </Button>
                                <Button Style="{StaticResource gridInforButton}" Margin="5 0 0 0" Click="ShowOwnerDetails_Click" 
                                    Tag="{Binding}">
                                    <Icon:PackIconMaterial Kind="Information" Style="{StaticResource GridButtunIcon}"/>
                                </Button>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

            </DataGrid.Columns>

        </DataGrid>

        <Border Grid.Row="6"    Background="#51a7bf" CornerRadius="10" 
                        Width="70" Margin="0 10 300 10">
            <TextBlock  Text="Trang"   FontSize="16" FontWeight="SemiBold"
                Foreground="#ffffff" HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Margin="0 0 0 0"/>
        </Border>

        <!--Pagination Section-->
        <Border Grid.Row="6" HorizontalAlignment="Center" BorderBrush="#dee4ec"
                BorderThickness="1" CornerRadius="5" Padding="5" Background="White"
                Margin="0 10 10 10">
            <StackPanel Orientation="Horizontal">

                <!-- Nút lùi trang -->
                <Button x:Name="btnPrev" Style="{StaticResource pagingButton}" Click="BtnPrev_Click">
                    <Icon:PackIconMaterial Kind="ChevronLeft" Style="{StaticResource pagingButtonIcon}"/>
                </Button>

                <Rectangle Width="1" Fill="#dee4ec" Margin="3 7"/>

                <!-- Các nút trang tĩnh (1,2,3,...) -->
                <Button Style="{StaticResource pagingButton}" Content="1" Click="PageButton_Click"/>
                <Button Style="{StaticResource pagingButton}" Content="2" Click="PageButton_Click"/>
                <Button Style="{StaticResource pagingButton}" Content="3" Click="PageButton_Click"/>
                <!-- ... tuỳ bạn đặt thêm các nút 4,5,... -->

                <Rectangle Width="1" Fill="#dee4ec" Margin="3 7"/>

                <!-- Nút tiến trang -->
                <Button x:Name="btnNext" Style="{StaticResource pagingButton}" Click="BtnNext_Click">
                    <Icon:PackIconMaterial Kind="ChevronRight" Style="{StaticResource pagingButtonIcon}"/>
                </Button>
            </StackPanel>
        </Border>

    </Grid>
</UserControl>
