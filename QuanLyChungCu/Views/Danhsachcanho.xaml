<UserControl x:Class="QuanLyChungCu.Views.Danhsachcanho"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:QuanLyChungCu.Views"
             xmlns:Icon="http://metro.mahapps.com/winfx/xaml/iconpacks"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="39*"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal" Grid.Row="2" Margin="0 0 0 0" HorizontalAlignment="Left">
            <ComboBox   x:Name="cmbSearchColumn"
                Style="{StaticResource CustomComboBoxStyle}"
                ItemContainerStyle="{StaticResource ComboBoxItemStyle}"
                Width="150" 
                Height="30"
                FontSize="14"
                Margin="0,0,10,0">
                <ComboBoxItem Content="Loại Phòng" Tag="LoaiPhong" IsSelected="True" />
                <ComboBoxItem Content="Giá Phòng" Tag="Giá Phòng"/>
                <ComboBoxItem Content="Diện Tích" Tag="DienTich"/>
                <ComboBoxItem Content="Còn Trống" Tag="Controng"/>
            </ComboBox>


            <Border Width="200" CornerRadius="20" Background="#ffffff" Height="30">
                <StackPanel Orientation="Horizontal">
                    <TextBox    x:Name="txtSearch" Background="Transparent"
                        Width="160" BorderBrush="Transparent"
                        Height="30"
                        FontSize="15" 
                        Margin="10,0,0,0"
                        VerticalContentAlignment="Center"
                        Text="Nhập từ khóa..."         
                        Foreground="Gray"
                        GotFocus="txtSearch_GotFocus" 
                        LostFocus="txtSearch_LostFocus" HorizontalAlignment="Left"/>
                    <Icon:PackIconMaterial Kind="Magnify" Width="15" Height="15" 
                        VerticalAlignment="Center" 
                        Margin="0 0 0 0" Foreground="#b0b9c6"
                        HorizontalAlignment="Right"/>
                </StackPanel>
            </Border>

            <Border Width="100" 
            Height="30" CornerRadius="10"
            Background="#ffffff" 
            Margin="10 0 0 0">

                <Button x:Name="btnSearch" Style="{StaticResource searchButton}" 
                Content="Tìm Kiếm"
                Width="100" Height="30"
                Click="btnSearch_Click" />
            </Border>
            <Rectangle Width="1" Fill="#dee4ec" Margin="10 7"/>
            <Border Width="100" 
            Height="30" CornerRadius="10"                           
            Background="#ffffff">
                <Button x:Name="btnClearSearch" 
                Style="{StaticResource searchButton}"                              
                Content="Xóa Lọc" 
                Width="100" Height="30" 
                Click="btnClearSearch_Click"/>
            </Border>
        </StackPanel>
        <DataGrid   Style="{DynamicResource DataGridStyle1}" CellStyle="{DynamicResource DataGridCellStyle1}" 
                    ColumnHeaderStyle="{DynamicResource DataGridColumnHeaderStyle1}"
                    RowStyle="{DynamicResource DataGridRowStyle1}" 
                    x:Name="MemberDataGrid"
                    Grid.Row="3">
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="Phòng" IsReadOnly="True" Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">

                                <TextBlock Text="{Binding MaCanHo}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Loại Phòng" IsReadOnly="True" Width="*" Binding="{Binding LoaiPhong}"/>
                <DataGridTextColumn Header="Giá Phòng" IsReadOnly="True" Width="*" Binding="{Binding GiaPhong}"/>
                <DataGridTextColumn Header="Diện Tích" IsReadOnly="True" Width="*" Binding="{Binding DienTich}"/>
                <DataGridTextColumn Header="Còn trống" IsReadOnly="True" Width="*" Binding="{Binding Controng}"/>
                


            </DataGrid.Columns>

        </DataGrid>
        <!--Pagination Section-->
        <Border Grid.Row="6" HorizontalAlignment="Center" BorderBrush="#dee4ec"
        BorderThickness="1" CornerRadius="5" Padding="5" Background="White"
        Margin="0 10 10 10">
            <StackPanel Orientation="Horizontal">

                <!-- Nút lùi trang -->
                <Button x:Name="btnPrev" Style="{StaticResource pagingButton}" Click="BtnPrev_Click">
                    <Icon:PackIconMaterial Kind="ChevronLeft" Style="{StaticResource pagingButtonIcon}"/>
                </Button>

                <Rectangle Width="1" Fill="#dee4ec" Margin="3 7"/>

                <!-- Các nút trang tĩnh (1,2,3,...) -->
                <Button Style="{StaticResource pagingButton}" Content="1" Click="PageButton_Click"/>
                <Button Style="{StaticResource pagingButton}" Content="2" Click="PageButton_Click"/>
                <Button Style="{StaticResource pagingButton}" Content="3" Click="PageButton_Click"/>
                <!-- ... tuỳ bạn đặt thêm các nút 4,5,... -->

                <Rectangle Width="1" Fill="#dee4ec" Margin="3 7"/>

                <!-- Nút tiến trang -->
                <Button x:Name="btnNext" Style="{StaticResource pagingButton}" Click="BtnNext_Click">
                    <Icon:PackIconMaterial Kind="ChevronRight" Style="{StaticResource pagingButtonIcon}"/>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
