<UserControl x:Class="QuanLyChungCu.Views.ReportsAdmin"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:QuanLyChungCu.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Border Background="White" CornerRadius="25" Padding="20" BorderBrush="Gray" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Text="📋 Danh sách khiếu nại" 
                       FontSize="24" FontWeight="Bold"
                       Foreground="#007ACC" Margin="0,0,0,10"/>

            <Border Grid.Row="1" Background="White" CornerRadius="20" 
                    Padding="10" BorderBrush="Gray" BorderThickness="1">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ListBox x:Name="ReportList" Background="Transparent">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="10" Margin="5" Background="#F5F5F5" CornerRadius="10">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Title}" FontWeight="Bold"/>
                                        <TextBlock Text="{Binding Date}" Foreground="Gray"/>
                                        <TextBlock Text="{Binding Content}" TextWrapping="Wrap" Margin="0,5,0,0"/>

                                        <!-- Hiển thị thông tin chủ hộ -->
                                        <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                            <TextBlock Text="Chủ hộ: " Foreground="DarkGray"/>
                                            <TextBlock Text="{Binding OwnerName}" FontWeight="SemiBold"/>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="SĐT: " Foreground="DarkGray"/>
                                            <TextBlock Text="{Binding OwnerPhone}"/>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Phòng: " Foreground="DarkGray"/>
                                            <TextBlock Text="{Binding OwnerRoom}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </ScrollViewer>
            </Border>
        </Grid>
    </Border>
</UserControl>