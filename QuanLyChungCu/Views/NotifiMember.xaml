<UserControl x:Class="QuanLyChungCu.Views.NotifiMember"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:QuanLyChungCu.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <!-- Bo tròn toàn bộ giao diện -->
    <Border Background="White" CornerRadius="25" Padding="20" BorderBrush="Gray" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Tiêu đề -->
                <RowDefinition Height="*"/>
                <!-- Danh sách thông báo -->
                <RowDefinition Height="Auto"/>
                <!-- Nhập thông báo -->
            </Grid.RowDefinitions>

            <!-- Tiêu đề -->
            <TextBlock Text="📋 Danh sách thông báo" FontSize="24" FontWeight="Bold"
                    VerticalAlignment="Center" Foreground="#007ACC" Margin="0,0,0,10"/>

            <!-- Danh sách thông báo -->
            <Border Background="White" CornerRadius="20" Padding="10" BorderBrush="Gray" BorderThickness="1" Grid.Row="1">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ListBox x:Name="NotificationList" Background="Transparent" ItemsSource="{Binding Notifications}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="10" Margin="5" Background="#F5F5F5" CornerRadius="10">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Title}" FontSize="16" FontWeight="Bold"/>
                                        <TextBlock Text="{Binding Date}" FontSize="14" Foreground="Gray"/>
                                        <TextBlock Text="{Binding Content}" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </ScrollViewer>
            </Border>
        </Grid>
    </Border>
</UserControl>
