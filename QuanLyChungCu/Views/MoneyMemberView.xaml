<UserControl x:Class="QuanLyChungCu.Views.MoneyMemberView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:QuanLyChungCu.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <Border Background="White" CornerRadius="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid Grid.Column="0" Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                </Grid.RowDefinitions>
                <Border Grid.Column="0" Grid.Row="1" Margin="10 20 0 20">
                    <StackPanel Orientation="Horizontal">
                    
                        <TextBlock Text="Tiền Điện:" Margin="10 10 0 0" FontSize="14"/>
                        <TextBlock Text="{Binding TienDien, StringFormat={}{0:N0} đ}" Margin="10 10 0 0" FontSize="14"/>
                    
                    </StackPanel>

                
                </Border>
                <Border Grid.Column="0" Grid.Row="2" Margin="10 10 0 10">
                    <StackPanel Orientation="Horizontal">

                        <TextBlock Text="Tiền Nước:" Margin="10 10 0 0" FontSize="14"/>
                        <TextBlock Text="{Binding TienNuoc, StringFormat={}{0:N0} đ}" Margin="10 10 0 0" FontSize="14"/>

                    </StackPanel>


                </Border>
                <Border Grid.Column="0" Grid.Row="3" Margin="10 10 0 10">
                    <StackPanel Orientation="Horizontal">

                        <TextBlock Text="Tiền Nhà:" Margin="10 10 0 0" FontSize="14"/>
                        <TextBlock Text="{Binding RoomRent, StringFormat={}{0:N0} đ}" Margin="10 10 0 0" FontSize="14"/>

                    </StackPanel>


                </Border>
                <Border Grid.Column="0" Grid.Row="4" Margin="10 10 0 10">
                    <StackPanel Orientation="Horizontal">

                        <TextBlock Text="Tiền Dịch Vụ:" Margin="10 10 0 0" FontSize="14"/>
                        <TextBlock Text="{Binding TienDichVu, StringFormat={}{0:N0} đ}" Margin="10 10 0 0" FontSize="14"/>

                    </StackPanel>


                </Border>
                <Border Grid.Column="0" Grid.Row="5" Margin="10 10 0 40">
                    <StackPanel Orientation="Horizontal">

                        <TextBlock Text="Tiền Tổng:" Margin="10 10 0 0" FontSize="14"/>
                        <TextBlock Text="{Binding TongTien, StringFormat={}{0:N0} đ}" Margin="10 10 0 0" FontSize="14"/>

                    </StackPanel>


                </Border>
                <Separator Margin="0" DockPanel.Dock="Top" Height="0.8" Background="#daf4ff"
                       Grid.Row="6" Grid.Column="0"/>
            </Grid>

            

            <Grid Grid.Row="2" Grid.Column="0">
                <StackPanel Orientation="Vertical">

                    <TextBlock Text="Đơn Giá" Margin="20 10 0 0" FontSize="16"/>
                    <TextBlock Text="Điện: 3,500/ 1kWh" Margin="20 10 0 0" FontSize="14"/>
                    <TextBlock Text="Nước: 30,000/ Khối" Margin="20 10 0 0" FontSize="14"/>
                    <TextBlock Text="Dịch vụ: 50,000 / người" Margin="20 10 0 0" FontSize="14"/>
    

                </StackPanel>
            </Grid>


            <Border Margin="0 100 0 0" Grid.Column="2" Grid.Row="1" Width="200" Height="200" HorizontalAlignment="Center">

                <Rectangle>
                    <Rectangle.Fill>
                        <ImageBrush ImageSource="/Image/qrcode-default.jpg"/>
                    </Rectangle.Fill>
                </Rectangle>
                
                

            </Border>
            <Border Grid.Column="2" Grid.Row="2" Width="200" Height="40"
                    Margin="0 50 0 50" CornerRadius="20">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#36D1DC" Offset="0.0"/>
                        <GradientStop Color="#5B86E5" Offset="1.0"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Button Background="Transparent" BorderBrush="Transparent">
                    <TextBlock Text="Quét QR Để Thanh Toán" FontSize="16" Foreground="#ffffff"/>
                </Button>
            </Border>

        </Grid>
    </Border>

</UserControl>
