<Window x:Class="QuanLyChungCu.EditMoney"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Chỉnh Sửa Thông Tin Tiền" 
        Height="250" 
        Width="300"
        WindowStartupLocation="CenterScreen" 
        WindowStyle="None" 
        AllowsTransparency="True" 
        Background="Transparent">

    <Border Background="#daf4ff" CornerRadius="30" MouseDown="Border_MouseDown">
    <Grid Margin="10 10 10 0">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>

        <Button x:Name="btnMinimize"                           
                BorderThickness="0"
                Grid.Row="0"
                Content="-"
                Foreground="White"
                FontSize="17"
                Cursor="Hand"
                Click="btnMinimize_Click"
                HorizontalAlignment="Right"
                Margin="0 0 25 0">
            <Button.Style>
                <Style TargetType="Button">
                    <Setter Property="Background" Value="#28AEED"/>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#278BEF"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Button.Style>
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Width="20" Height="20"
                CornerRadius="10"
                Background="{TemplateBinding Background}">
                        <ContentPresenter VerticalAlignment="Center"
                              HorizontalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Button.Template>
        </Button>
        <Button x:Name="btnClose"                          
                BorderThickness="0"
                Content="X"
                Grid.Row="0"
                Foreground="White"
                FontSize="13"
                Cursor="Hand"
                Grid.Column="2"
                Click="btnClose_Click"
                HorizontalAlignment="Right">
            <Button.Style>
                <Style TargetType="Button">
                    <Setter Property="Background" Value="#FFDA5A34"/>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#C62DAE"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Button.Style>
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Width="20" Height="20"
                            CornerRadius="10"
                            Background="{TemplateBinding Background}">
                        <ContentPresenter   VerticalAlignment="Center"
                                            HorizontalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Button.Template>
        </Button>

        <Border Grid.Row="1" Margin="0 2 0 2">
            <StackPanel Orientation="Horizontal">
                <Border Margin="10" Background="#51a7bf" CornerRadius="7" 
                        Height="25" Width="65">
                        <TextBlock  Text="Tiền Phòng" 
                                VerticalAlignment="Center" 
                                HorizontalAlignment="Center" Foreground="#ffffff" />
                </Border>

                <Border CornerRadius="10" Background="#ffffff"

                        Margin="13 10 10 10" Width="159">
                        <TextBox    x:Name="txtRoomRent" 
                                Background="Transparent"
                                BorderBrush="Transparent"/>
                </Border>

            </StackPanel>
        </Border>

        <Border Grid.Row="2" Margin="0 2 0 2">
            <StackPanel Orientation="Horizontal">
                <Border Margin="10" Background="#51a7bf" CornerRadius="7" 
                        Height="25" Width="65">
                    <TextBlock  Text="Số Điện:" 
                                VerticalAlignment="Center" 
                                HorizontalAlignment="Center" Foreground="#ffffff" />
                </Border>

                <Border CornerRadius="10" Background="#ffffff"
            
                        Margin="13 10 10 10" Width="159">
                    <TextBox    x:Name="txtPower"
                                Background="Transparent"
                                BorderBrush="Transparent"/>
                </Border>

            </StackPanel>
        </Border>

            <Border Grid.Row="3" Margin="0 2 0 2">
                <StackPanel Orientation="Horizontal">
                    <Border Margin="10" Background="#51a7bf" CornerRadius="7" 
                        Height="25" Width="65">
                        <TextBlock Text="Số Nước:" 
                               VerticalAlignment="Center" 
                               HorizontalAlignment="Center" Foreground="#ffffff"/>
                    </Border>

                    <Border CornerRadius="10" Background="#ffffff"
                        
                        Margin="13 10 10 10" Width="159">
                        <TextBox x:Name="txtWater" 
                             Background="Transparent"
                             BorderBrush="Transparent"/>
                    </Border>

                </StackPanel>
            </Border>

            <Border Grid.Row="6" Margin="30 15 10 10"
                Background="#51a7bf" Width="100" 
                CornerRadius="7">
            <Button Content="Lưu" Grid.Row="5"
                    FontSize="16" Foreground="#ffffff"
                    Click="btnSave_Click" Width="100" 
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="Transparent" IsDefault="True"
                    BorderBrush="Transparent" Height="38"/>
        </Border>


    </Grid>
</Border>
</Window>