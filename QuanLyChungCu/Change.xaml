<Window x:Class="QuanLyChungCu.Change"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:QuanLyChungCu"
        mc:Ignorable="d"
        Title="Change" Height="220" Width="300" WindowStartupLocation="CenterScreen" WindowStyle ="None" AllowsTransparency="True" Background="Transparent">
    <Border Background="#e2e2e2" CornerRadius="30" MouseDown="Border_MouseDown" MouseLeftButtonDown="Border_MouseLeftButunDown">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="30"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <StackPanel VerticalAlignment="Bottom">
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="25"/>
                        <ColumnDefinition Width="20"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Chỉnh sửa cư dân" Grid.Row="2" Margin="20 10 5 8"
                               HorizontalAlignment="Left" Foreground="#121518"
                               VerticalAlignment="Center" FontWeight="Bold"/>
                    <Button x:Name="btnClose"                          
                            BorderThickness="0"
                            Content="X"
                            Foreground="White"
                            FontSize="13"
                            Cursor="Hand"
                            Grid.Column="1"
                            Click="btnClose_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#FFDA5A34"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#C62DAE"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Width="20" Height="20"
                                        CornerRadius="10"
                                        Background="{TemplateBinding Background}">
                                    <ContentPresenter VerticalAlignment="Center"
                                                      HorizontalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </StackPanel>
            <TextBlock Text="Tên:" Grid.Row="2" Margin="20 10 5 0"
                       HorizontalAlignment="Left" Foreground="#121518"
                       VerticalAlignment="Center"/>
            <TextBox x:Name="txtName" Grid.Row="2" Margin="100,10,10,5"
                 BorderBrush="Transparent"/>

            <TextBlock Text="Số ĐT:" Grid.Row="3" Margin="20 10 5 0"
                       HorizontalAlignment="Left" Foreground="#121518"/>
            <TextBox x:Name="txtSDT" Grid.Row="3" Margin="100,10,10,5"
                       BorderBrush="Transparent"/>

            <TextBlock Text="Số Người Ở:" Grid.Row="4" Margin="20 10 5 0"
                       HorizontalAlignment="Left" Foreground="#121518"/>
            <TextBox x:Name="txtSoNguoiO" Grid.Row="4" Margin="100,10,10,5"
                 BorderBrush="Transparent"/>

            <TextBlock Text="Vị Trí:" Grid.Row="5" Margin="20 10 5 0"
                       HorizontalAlignment="Left" Foreground="#121518"/>
            <TextBox x:Name="txtViTri" Grid.Row="5" Margin="100,10,10,5"
                     BorderBrush="Transparent"/>

            <Border Grid.Row="6" Background="#51a7bf" CornerRadius="10"
                    Width="50" Height="40" Margin="5">
                <Button Content="Lưu"  Click="btnAdd_Click" Margin="10"
                        Width="50" Background="Transparent" Foreground="#ffffff"
                        BorderBrush="Transparent" VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Style="{StaticResource topButton}">
                </Button>
            </Border>
        </Grid>
    </Border>
</Window>
