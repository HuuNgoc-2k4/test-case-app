<Window x:Class="QuanLyChungCu.ChangerPassword"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Đổi Mật Khẩu" Height="550" Width="900"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        FontFamily="Arial"
        AllowsTransparency="True">
    <Border CornerRadius="25">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#e2e2e2" Offset="0.3"/>
                <GradientStop Color="#c5d6fd" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <!-- Phần bên phải giao diện không thay đổi -->
            <Border Grid.Column="1" CornerRadius="100 25 25 100">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#6996f0" Offset="0"/>
                        <GradientStop Color="#7981ef" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="50"/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="25"/>
                            <ColumnDefinition Width="25"/>
                            <ColumnDefinition Width="30"/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="btnMinimize"                           
                                BorderThickness="0"
                                Content="-"
                                Foreground="White"
                                FontSize="17"
                                Cursor="Hand"
                                Grid.Column="1"
                                Click="btnMinimize_Click">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#acc8ff"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#278BEF"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Width="20" Height="20"
                                            CornerRadius="10"
                                            Background="{TemplateBinding Background}">
                                        <ContentPresenter VerticalAlignment="Center"
                                                          HorizontalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button x:Name="btnClose"                          
                                BorderThickness="0"
                                Content="X"
                                Foreground="White"
                                FontSize="13"
                                Cursor="Hand"
                                Grid.Column="2"
                                Click="btnClose_Click">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#FFDA5A34"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#C62DAE"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Width="20" Height="20"
                                            CornerRadius="10"
                                            Background="{TemplateBinding Background}">
                                        <ContentPresenter VerticalAlignment="Center"
                                                          HorizontalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                    <StackPanel Width="300"
                                Grid.Row="1"
                                Orientation="Vertical"
                                Margin="0 40 0 0">
                        <TextBox Height="270" BorderThickness="0">
                            <TextBox.Background>
                                <ImageBrush ImageSource="/Image/Untitled-2.png"
                                            Stretch="Fill"
                                            AlignmentX="Left"/>
                            </TextBox.Background>
                        </TextBox>

                        <TextBlock Text="QUẢN LÝ CHUNG CƯ"
                                   Foreground="White"
                                   FontSize="25"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"/>
                        <Button x:Name="btnLogin"                          
                                BorderThickness="0"
                                Content="Đăng Nhập"                           
                                FontSize="20"
                                FontWeight="Bold"
                                Cursor="Hand"               
                                Margin="0,20,0,0"
                                Click="btnLogin_Click">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="White"/>
                                            <Setter Property="Foreground" Value="#6996f0"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Width="180" Height="50"
                                            CornerRadius="10"
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="White" 
                                            BorderThickness="2">
                                        <ContentPresenter VerticalAlignment="Center"
                                                          HorizontalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Phần giao diện đổi mật khẩu ở bên trái -->
            <Grid Grid.Column="0">
                <StackPanel Grid.Row="1"
                            Width="350"
                            Orientation="Vertical"
                            Margin="0 37 0 0">
                    <TextBlock Text="Đổi Mật Khẩu"
                               Foreground="#2e3134"
                               FontSize="40"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"/>

                    <Grid Margin="0 30 0 0">
                        <TextBlock Text="Tài Khoản:" 
                                   Foreground="#8f8f8f"
                                   Margin="10 0 0 0"
                                   FontSize="15"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Left"/>
                        <TextBox x:Name="txtUser"
                                 Margin="0,25,0,0"
                                 Height="50"
                                 FontSize="15"
                                 FontWeight="Medium"
                                 Foreground="#8f8f8f"
                                 CaretBrush="LightGray"
                                 VerticalContentAlignment="Center"
                                 BorderBrush="Transparent"
                                 BorderThickness="0"
                                 Padding="20,0,10,0"
                                 IsReadOnly="False"/>
                        <Image Source="/Image/user-icon.png"
                               Width="20"
                               Height="20"
                               VerticalAlignment="Top"
                               HorizontalAlignment="Left"
                               Margin="320,40,0,0" RenderTransformOrigin="15.274,1.26"/>
                    </Grid>

                    <Grid Margin="0 15 0 0">
                        <TextBlock Text="Mật Khẩu hiện tại:" 
                                   Foreground="#8f8f8f"
                                   Margin="10 0 0 0"
                                   FontSize="15"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Left"/>
                        <PasswordBox x:Name="txtCurrentPassword"
                                     Margin="0,25,0,0"
                                     Height="50"
                                     FontSize="15"
                                     FontWeight="Medium"
                                     Foreground="#8f8f8f"
                                     CaretBrush="LightGray"
                                     VerticalContentAlignment="Center"
                                     BorderBrush="Transparent"
                                     BorderThickness="0"
                                     Padding="20,0,10,0"/>
                        <TextBox x:Name="txtCurrentPasswordVisible"
                                 Height="50" FontSize="15" Foreground="#8f8f8f"
                                 BorderBrush="Transparent" Padding="20,0,10,0"
                                 Margin="0,25,0,0" Visibility="Collapsed" IsReadOnly="True"
                                 FontWeight="Medium" VerticalContentAlignment="Center" BorderThickness="0"/>
                        <Image Source="/Image/key-icon.png"
                               Width="20"
                               Height="20"
                               VerticalAlignment="Top"
                               HorizontalAlignment="Left"
                               Margin="320,40,0,0" RenderTransformOrigin="15.274,1.26"/>
                    </Grid>

                    <Grid Margin="0 15 0 0">
                        <TextBlock Text="Mật khẩu mới:"  
                                   Foreground="#8f8f8f"  
                                   Margin="10 0 0 0"  
                                   FontSize="15"  
                                   FontWeight="Bold"  
                                   HorizontalAlignment="Left"/>
                        <PasswordBox x:Name="txtNewPassword"
                                     Margin="0,25,0,0"
                                     Height="50"
                                     FontSize="15"
                                     FontWeight="Medium"
                                     Foreground="#8f8f8f"
                                     CaretBrush="LightGray"
                                     VerticalContentAlignment="Center"
                                     BorderBrush="Transparent"
                                     BorderThickness="0"
                                     Padding="20,0,10,0"/>
                        <TextBox x:Name="txtNewPasswordVisible"
                                 Height="50" FontSize="15" Foreground="#8f8f8f"
                                 BorderBrush="Transparent" Padding="20,0,10,0"
                                 Margin="0,25,0,0" Visibility="Collapsed" IsReadOnly="True"
                                 FontWeight="Medium" VerticalContentAlignment="Center" BorderThickness="0"/>
                        <Image Source="/Image/key-icon.png"  
                               Width="20"  
                               Height="20"  
                               VerticalAlignment="Top"  
                               HorizontalAlignment="Left"  
                               Margin="320,40,0,0"  
                               RenderTransformOrigin="15.274,1.26"/>
                    </Grid>

                    <CheckBox x:Name="chkShowPassword"
                              Content="Hiển thị mật khẩu"
                              Checked="chkShowPassword_Checked"
                              Unchecked="chkShowPassword_Unchecked"
                              Height="40"
                              FontSize="15"
                              FontWeight="Bold"
                              Foreground="#8f8f8f"
                              VerticalContentAlignment="Center"
                              Margin="0,5,0,0"/>

                    <Button x:Name="btnChangePassword"                          
                            BorderThickness="0"
                            Content="Đổi Mật Khẩu"                           
                            FontSize="20"
                            FontWeight="Bold"
                            Cursor="Hand"               
                            Margin="0,20,0,0"
                            Click="btnChangePassword_Click"
                            IsDefault="True">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#7389ef"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="White"/>
                                        <Setter Property="Foreground" Value="#6996f0"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Width="200" Height="50"
                                        CornerRadius="10"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="White" 
                                        BorderThickness="0">
                                    <ContentPresenter VerticalAlignment="Center"
                                                      HorizontalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
