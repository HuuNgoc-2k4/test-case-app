<Window x:Class="QuanLyChungCu.Programs"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:Icon="http://metro.mahapps.com/winfx/xaml/iconpacks"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:QuanLyChungCu"
        Title="Quản Lý Chung Cư"
        mc:Ignorable="d"
        Height="720" Width="1080" WindowStartupLocation="CenterScreen" WindowStyle ="None" AllowsTransparency="True" Background="Transparent">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>
    <Border Background="#eff2f7" CornerRadius="30" MouseDown="Border_MouseDown" >
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!--LeftMenu-->
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <!-- Menu Icon -->
                <Button Margin="20 28 0 35" Style="{StaticResource topButton}" HorizontalAlignment="Left">
                    <Icon:PackIconMaterial Kind="Menu" Width="15" Height="15"/>
                </Button>
                <Border Grid.Row="1" CornerRadius="0 50 0 30" >
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#6996f0" Offset="0"/>
                            <GradientStop Color="#7981ef" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <DockPanel>
                        <Border Width="80" Height="80" Padding="3" Background="White" CornerRadius="100"
                            DockPanel.Dock="Top" HorizontalAlignment="Left" Margin=" 20 -30 0 0">
                            <Ellipse>
                                <Ellipse.Fill>
                                    <ImageBrush ImageSource="/Image/logo-truong-dai-hoc-kien-truc-ha.jpg"/>
                                </Ellipse.Fill>
                            </Ellipse>
                        </Border>
                        <TextBlock Text="Tòa Nhà NPQQS" Foreground="#daf4ff" FontSize="20"
                             FontWeight="SemiBold" Background="Transparent"
                             DockPanel.Dock="Top"
                             TextAlignment="Center" Margin="5 25 0 10">
                        </TextBlock>
                        <TextBlock Text="Quản Lý" Foreground="#daf4ff" FontSize="14"
                             FontWeight="SemiBold" Background="Transparent"
                             DockPanel.Dock="Top" TextAlignment="Center">
                        </TextBlock>
                        <Separator Margin="25" DockPanel.Dock="Top" Height="0.8" Background="#daf4ff">

                        </Separator>
                        <StackPanel DockPanel.Dock="Top">
                            <Button Style="{StaticResource menuButton}" Click="Button_Click_1">
                                <StackPanel Orientation="Horizontal">
                                    <Icon:PackIconMaterial Kind="HumanCapacityDecrease" Style="{StaticResource menuButtonIcon}"/>
                                    <TextBlock Text="Danh Sách Cư dân"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource menuButton}" Click="Button_Click_2">
                                <StackPanel Orientation="Horizontal">
                                    <Icon:PackIconMaterial Kind="DiamondOutline" Style="{StaticResource menuButtonIcon}"/>
                                    <TextBlock Text="Tiền dịch vụ"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource menuButton}" Click="Button_Click" >
                                <StackPanel Orientation="Horizontal">
                                    <Icon:PackIconMaterial Kind="NotificationClearAll" Style="{StaticResource menuButtonIcon}"/>
                                    <TextBlock Text="Gửi thông báo"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource menuButton}" Click="Button_Click_4" >
                                <StackPanel Orientation="Horizontal">
                                    <Icon:PackIconMaterial Kind="ChatQuestion" Style="{StaticResource menuButtonIcon}"/>
                                    <TextBlock Text="Vấn đề"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource menuButton}" Click="Button_Click_3"  >
                                <StackPanel Orientation="Horizontal">
                                    <Icon:PackIconMaterial Kind="Home" Style="{StaticResource menuButtonIcon}"/>
                                    <TextBlock Text="Danh Sách Căn Hộ"/>
                                </StackPanel>
                            </Button>
                            
                        </StackPanel>
                        <Button Style="{StaticResource menuButton}" VerticalAlignment="Bottom"
                            DockPanel.Dock="Bottom" Margin="15 10" Click="btnLogOut_Click">
                            <StackPanel Orientation="Horizontal">
                                <Icon:PackIconMaterial Kind="Logout" Style="{StaticResource menuButtonIcon}"/>
                                <TextBlock Text="Đăng xuất"/>
                            </StackPanel>
                        </Button>
                    </DockPanel>
                </Border>
            </Grid>
            <!-- Main Menu -->
            <Grid Grid.Column="1" Margin="30 10 20 10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="2*"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="39*"/>
                    <RowDefinition Height="auto"/>
                </Grid.RowDefinitions>                
                    <Button x:Name="btnMinimize"                           
                        BorderThickness="0"
                        Grid.Row="0"
                        Content="-"
                        Foreground="White"
                        FontSize="17"
                        Cursor="Hand"
                        Click="btnMinimize_Click"
                        HorizontalAlignment="Right"
                        Margin="0 0 25 0">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#28AEED"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#278BEF"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Width="20" Height="20"
                                    CornerRadius="10"
                                    Background="{TemplateBinding Background}">
                                <ContentPresenter VerticalAlignment="Center"
                                                  HorizontalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                    <Button x:Name="btnClose"                          
                        BorderThickness="0"
                        Content="X"
                        Grid.Row="0"
                        Foreground="White"
                        FontSize="13"
                        Cursor="Hand"
                        Grid.Column="2"
                        Click="btnClose_Click"
                        HorizontalAlignment="Right">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#FFDA5A34"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#C62DAE"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Width="20" Height="20"
                    CornerRadius="10"
                    Background="{TemplateBinding Background}">
                                <ContentPresenter VerticalAlignment="Center"
                                  HorizontalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                
                <!--Page Title-->
                <TextBlock Text="Tòa Nhà NPQQS" Grid.Row="1" FontSize="32" FontWeight="SemiBold"
                           Margin="0"
                           HorizontalAlignment="Left" Foreground="#121518">
                </TextBlock>

                <!--Separator--> 
                <Separator Height="1" Grid.Row="2" Background="#dae2ea"
                           Margin="0 -1 0 10"/>
                                                                                                             

                
                <Grid Grid.Row="5" Margin="0">
                    <ContentControl x:Name="MainContent">
                        <Grid Grid.Row="3">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="auto"/>
                                <RowDefinition Height="auto"/>
                                <RowDefinition Height="auto"/>
                                <RowDefinition Height="auto"/>
                                <RowDefinition Height="auto"/>
                                <RowDefinition Height="39*"/>
                                <RowDefinition Height="auto"/>
                            </Grid.RowDefinitions>

                        </Grid>
                    </ContentControl>
                </Grid>
                
                        
                
                

            </Grid>
        </Grid>
    </Border>
</Window>
